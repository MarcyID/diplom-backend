# Kinopoisk API
KINOPOISK_API_KEY=your-api-key-here

# Server
PORT=5454

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=diplom_db
DB_SSLMODE=disable

# JWT Secret (CHANGE IN PRODUCTION!)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-key-change-in-production-min-32-chars

# CORS allowed origins (comma-separated, no spaces)
# React: http://localhost:3000, Vite: http://localhost:5173
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# 📦 CACHING Kinopoisk API
# Cache type: memory (default) or redis
CACHE_TYPE=memory
# Cache TTL in hours (default 24 hours)
CACHE_TTL_HOURS=24

# Redis (optional, if CACHE_TYPE=redis)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
